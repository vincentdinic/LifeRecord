- is_own_profile = current_user == @user

.container
  .header-card
    .row.align-items-center
      .col-2
        .record-actions
          = link_to "Back",
            root_path,
            class: "action-btn btn btn-secondary"
      .col-8.text-center
        %h1
          = @user.full_name
      .col-2
        - if is_own_profile
          .record-actions.justify-content-end
            = link_to "Edit",
              edit_user_path(@user),
              class: "btn btn-primary action-btn"

  .body-card
    = render "education_records/list", user: @user, is_own_profile: is_own_profile

  -# .body-card
  -#   = render "employment_records/list", user: @user, is_own_profile: is_own_profile

  .body-card
    .section-header.d-flex.justify-content-between.align-items-center.mb-3
      %h3.mb-0 Documents
      - if is_own_profile
        = link_to "Add Document",
          new_user_document_path(@user),
          class: "btn btn-primary btn-sm"
    - if @user.documents.any?
      - @user.documents.order(created_at: :desc).each do |document|
        = render "documents/document", document: document
    - else
      %p.text-muted No documents yet.