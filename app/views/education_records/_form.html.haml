- url = @education_record.persisted? ? education_record_path(@education_record) : user_education_records_path(@user)

= form_with(model: @education_record, url: url) do |form|
  .form-group.mb-3
    = form.label :school_name, "School Name *", class: "form-label"
    = form.text_field :school_name, required: true, class: "form-control"

  .d-flex.mb-3
    .form-group.me-2.w-50
      = form.label :degree_type, "Degree Type *", class: "form-label"
      = form.select :degree_type,
          EducationRecord.degree_types.keys.map { |k| [k.humanize, k] },
          { include_blank: "Select a type" },
          class: "form-control",
          required: true

    .form-group.w-50
      = form.label :field_of_study, "Field of Study", class: "form-label"
      = form.text_field :field_of_study, class: "form-control"

  .d-flex.mb-3
    .form-group.w-25.me-2
      = form.label :city, "City", class: "form-label"
      = form.text_field :city, class: "form-control"
    .form-group.w-25.me-2
      = form.label :state, "State", class: "form-label"
      = form.text_field :state, class: "form-control"
    .form-group.w-25
      = form.label :country, "Country", class: "form-label"
      = form.text_field :country, class: "form-control"

  .d-flex.mb-3
    .form-group.me-2.w-25
      = form.label :start_date, "Start Date *", class: "form-label"
      = form.date_field :start_date, required: true, class: "form-control"
    .form-group.w-25
      = form.label :end_date, "End Date", class: "form-label"
      = form.date_field :end_date, class: "form-control"

  .form-group.mb-3
    .form-check
      = form.check_box :current, class: "form-check-input"
      = form.label :current, "Currently attending", class: "form-check-label"

  .form-group.mb-3
    = form.label :gpa, "GPA", class: "form-label"
    = form.number_field :gpa, class: "form-control", min: 0.0, max: 4.0, step: 0.01, placeholder: "0.00"
    .form-text Out of 4.0

  .record-actions
    = form.submit "Save", class: "action-btn btn btn-success"