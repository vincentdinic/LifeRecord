.container
  .body-card
    %h3.mb-3
      %strong
        New Event
    = form_with(model: [@current_family, event]) do |form|
      .form-group.mb-3
        = form.label :title, "Event Title", class: "form-label"
        = form.text_field :title, required: true, class: "form-control"
      .form-group.mb-3
        = form.label :description, "Event Description", class: "form-label"
        = form.textarea :description, class: "form-control"
      .form-group.mb-3
        = form.label :start_time, "Event Start", class: "form-label"
        = form.datetime_local_field :start_time, class: "form-control"
      .form-group.mb-3
        = form.label :end_time, "Event End", class: "form-label"
        = form.datetime_local_field :end_time, class: "form-control"
      
      .record-actions
        = form.submit "Save", class: "action-btn btn btn-success"
