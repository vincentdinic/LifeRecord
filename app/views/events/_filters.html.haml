.collapse#event-filters{ class: ("show" if filters_active?(params)) }
  .body-card
    = form_with url: family_calendar_path(@current_family),
                method: :get,
                data: { turbo: false },
                class: "p-3" do |f|

      .row.g-2
        .col-md-3
          = f.label :name, "Event Name", class: "form-label"
          = f.text_field :name, value: params[:name], class: "form-control"

        .col-md-3
          = f.label :start_date, "Start After", class: "form-label"
          = f.datetime_local_field :start_date, value: params[:start_date], class: "form-control"

        .col-md-3
          = f.label :end_date, "End Before", class: "form-label"
          = f.datetime_local_field :end_date, value: params[:end_date], class: "form-control"

        .col-md-3
          = f.label :user_id, "User", class: "form-label"
          = f.collection_select :user_id,
                                @current_family.users,
                                :id,
                                :full_name,
                                { include_blank: "All Users", selected: params[:user_id] },
                                { class: "form-select" }

      .mt-3
        = f.submit "Apply Filters", class: "btn btn-success"
        = link_to "Clear Filters",
                  family_calendar_path(@current_family),
                  class: "btn btn-secondary ms-2"