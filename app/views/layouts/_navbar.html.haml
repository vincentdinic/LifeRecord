%nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
    .container-fluid
        = link_to root_path, class: "navbar-brand" do
            = image_tag "life_record.png",
                width: 160,
                class: "ms-2 me-5"
        %button.navbar-toggler{ type: "button",
                                    data: { bs_toggle: "collapse", bs_target: "#navbarSupportedContent" },
                                    aria: { controls: "navbarSupportedContent",
                                            expanded: "false",
                                            label: "Toggle navigation" } }
            %span.navbar-toggler-icon
        .collapse.navbar-collapse#navbarSupportedContent
            %ul.navbar-nav.me-auto.mb-lg-0.fs-4
                - if current_user
                    - if current_user.families.any?
                        %li.nav-item.dropdown.me-5
                            - if current_user.families.size > 1
                                = link_to "Families",
                                            "#",
                                            class: "nav-link dropdown-toggle",
                                            role: "button",
                                            data: { bs_toggle: "dropdown" },
                                            aria: { expanded: "false" }

                                %ul.dropdown-menu.dropdown-menu-dark.bg-dark
                                    - current_user.families.each do |family|
                                        - family_class = family == @current_family ? "dropdown-item text-primary" : "dropdown-item"
                                        %li
                                            = link_to family.name,
                                                    family_path(family),
                                                    class: family_class
                                        - unless family == current_user.families.last 
                                            %li
                                                %hr.dropdown-divider.border-light.opacity-25

                            - else
                                = link_to "Family", family_path(@current_family), class: "nav-link"
                        %li.nav-item.me-5
                            = link_to "Calendar", family_calendar_path(@current_family), class: "nav-link"
                        %li.nav-item.me-5
                            = link_to "Finances", family_accounts_path(@current_family), class: "nav-link"
                        %li.nav-item.me-5
                            = link_to "Property", "#", class: "nav-link"
                        %li.nav-item.me-5
                            = link_to "Vehicles", "#", class: "nav-link"

                - else 
                    %li.nav-item.me-5
                        = link_to "About", root_path, class: "nav-link"

            %ul.navbar-nav.ms-auto.fs-4
                = render "users/session_manager"