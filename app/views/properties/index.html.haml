- content_for :title, "Properties"
- admin = @current_family.admin?(current_user)

.container
  .header-card
    .row
      .col-2
      .col-8
        %h1 Properties
      .col-2
        - if admin
          .record-actions.justify-content-end.align-items-center
            = link_to "New Property", new_family_property_path, class: 'btn btn-success'

  .body-card
    - if @properties.any?
      .properties.list-group
        - @properties.each do |property|
          .property.border.rounded.p-3.position-relative
            = render property
    - else
      .text-muted No properties added yet.

