= form_with(model: @document, url: form_url, html: { multipart: true }) do |form|
  .form-group.mb-3
    = form.label :title, "Title *", class: "form-label"
    = form.text_field :title, required: true, class: "form-control"

  .form-group.mb-3
    = form.label :description, "Description", class: "form-label"
    = form.text_area :description, class: "form-control"

  .form-group.mb-3
    = form.label :document_type, "Document Type *", class: "form-label"
    = form.select :document_type,
        Document.document_types.keys.map { |k| [k.humanize, k] },
        { include_blank: "Select a type" },
        class: "form-select",
        required: true

  .form-group.mb-3
    = form.label :file, "File", class: "form-label"
    - if @document.file.attached?
      .form-text.mb-2
        Current file:
        = link_to @document.file.filename, url_for(@document.file), target: "_blank"
    = form.file_field :file, required: !@document.file.attached?, class: "form-control", accept: "application/pdf,image/*"
    - if @document.file.attached?
      .form-text Leave blank to keep the current file.

  .record-actions
    = form.submit "Save", class: "action-btn btn btn-success"