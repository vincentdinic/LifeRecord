.container
  .header-card
    .row.align-items-center
      .col-2
        .record-actions
          = link_to "Back",
            document_path(@document),
            class: "action-btn btn btn-secondary"
      .col-8.text-center
        %h1 Edit Document
      .col-2
        .record-actions.justify-content-end
          = link_to "Delete",
            document_path(@document),
            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
            class: "btn btn-danger action-btn"

  .body-card
    = render "form"