- flash.each do |type, message|
  - bootstrap_class = case type.to_sym
    - when :notice then "alert alert-info alert-dismissible fade show"
    - when :alert then "alert alert-danger alert-dismissible fade show"
    - when :success then "alert alert-success alert-dismissible fade show"
    - else "alert alert-secondary alert-dismissible fade show"
  %div{ class: bootstrap_class, role: "alert" }
    = message
    %button{ type: "button", class: "btn-close", data: { bs_dismiss: "alert" }, aria: { label: "Close" } }